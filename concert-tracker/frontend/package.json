{
  "name": "concert-tracker-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript sources for concert-tracker's frontend. Compiles to ../static/*.js (committed build artifacts) via esbuild.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "test:story": "vitest run",
    "openapi-types": "openapi-typescript /tmp/concert-tracker-openapi.json -o src/generated/openapi.d.ts"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.83",
    "effect": "4.0.0-beta.83",
    "foldkit": "0.114.1"
  },
  "devDependencies": {
    "@foldkit/oxlint-plugin": "0.1.0",
    "esbuild": "0.28.1",
    "happy-dom": "20.10.6",
    "openapi-typescript": "7.13.0",
    "oxlint": "1.72.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
