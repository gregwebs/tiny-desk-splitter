# concert-tracker/static/{player,playlists,splitter}.js are committed build
# artifacts generated by `concert-tracker/frontend/build.mjs` from TypeScript
# sources (see concert-tracker/frontend/src/). Force LF so a checkout on a
# different platform/editor config can't produce line-ending noise that would
# fail `just ts-verify`'s `git diff --exit-code` drift check.
concert-tracker/static/player.js text eol=lf
concert-tracker/static/playlists.js text eol=lf
concert-tracker/static/splitter.js text eol=lf
